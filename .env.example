# Database (existing citas-db-1 container)
DB_NAME=truc
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# JWT secret — use a long random string
JWT_SECRET=change_me_to_a_long_random_secret

# Frontend public URL (used in invitation and password-reset emails)
FRONTEND_URL=http://your-server-ip:8081

# SMTP configuration
SMTP_HOST=your-smtp-host.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=smtp_password
SMTP_FROM=truc@your-domain.com
